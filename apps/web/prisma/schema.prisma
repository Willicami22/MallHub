model AiRun {
  id                String      @id @default(cuid())
  mallId            String?     @map("mall_id")
  storeId           String?     @map("store_id")
  requestedByUserId String      @map("requested_by_user_id")
  jobType           AiJobType   @map("job_type")
  jobStatus         AiJobStatus @default(QUEUED) @map("job_status")
  promptText        String?     @map("prompt_text")
  responseText      String?     @map("response_text")
  errorMessage      String?     @map("error_message")
  createdAt         DateTime    @default(now()) @map("created_at")

  mall            Mall?  @relation(fields: [mallId], references: [id], onDelete: SetNull)
  store           Store? @relation(fields: [storeId], references: [id], onDelete: SetNull)
  requestedByUser User   @relation("AiRunRequester", fields: [requestedByUserId], references: [id], onDelete: Cascade)

  @@index([mallId, jobType], map: "ai_runs_mall_jobType_idx")
  @@index([storeId, jobType], map: "ai_runs_store_jobType_idx")
  @@index([requestedByUserId], map: "ai_runs_requestedByUserId_idx")
  @@map("ai_runs")
}

model AdminCcAssignment {
