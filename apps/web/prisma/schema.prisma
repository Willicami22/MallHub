generator client {
  provider = "prisma-client"
  output   = "../app/features/.server/prisma/generated"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  CUSTOMER
  ADMIN_LOCAL
  ADMIN_CC
  ADMIN_PLATFORM
}

enum MallStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum StoreStatus {
  DRAFT
  PENDING_APPROVAL
  ACTIVE
  REJECTED
  SUSPENDED
}

enum StoreRegistrationRequestStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ProductStatus {
  DRAFT
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum ModerationReportStatus {
  OPEN
  RESOLVED
  DISMISSED
}

enum ModerationReportTargetType {
  PRODUCT
  STORE_PROFILE
  MALL_PROFILE
  STORE_IMAGE
  MALL_IMAGE
}

enum ModerationDecisionAction {
  PRODUCT_REMOVED
  REPORT_DISMISSED
  STORE_PROFILE_CORRECTED
  MALL_PROFILE_CORRECTED
  STORE_IMAGE_REMOVED
  MALL_IMAGE_REMOVED
}

enum PromotionStatus {
  DRAFT
  ACTIVE
  INACTIVE
  EXPIRED
}

enum ReservationStatus {
  PENDING
  CONFIRMED
  COMPLETED
  REJECTED
  CANCELED
}

enum AiJobType {
  PRODUCT_DRAFT
  MALL_REPORT
}

enum AiJobStatus {
  QUEUED
  SUCCESS
  FAILED
}

enum AuditEventOutcome {
  SUCCESS
  FAILURE
}

enum PlatformServiceKey {
  DATABASE
  BETTER_AUTH
  NOTIFICATIONS
  METRICS_PIPELINE
}

enum PlatformServiceStatus {
  OPERATIONAL
  DEGRADED
  INCIDENT
}

enum PlatformHealthIncidentStatus {
  OPEN
  RESOLVED
}

enum BillingTargetType {
  MALL
  STORE
}

enum BillingPlanCode {
  BASIC
  STANDARD
  PREMIUM
}

enum BillingSubscriptionStatus {
  ACTIVE
  OVERDUE
  SUSPENDED
}

enum BillingPaymentMethod {
  CASH
  BANK_TRANSFER
  CREDIT_CARD
  DEBIT_CARD
  OTHER
}

enum CampaignStatus {
  DRAFT
  ACTIVE
  PAUSED
  EXPIRED
}

enum CampaignBannerType {
  IMAGE
  NATIVE_CARD
}

model User {
  id              String    @id
  name            String
  email           String    @unique
  emailVerified   Boolean   @default(false) @map("email_verified")
  image           String?
  role            UserRole  @default(CUSTOMER)
  phone           String?
  preferredMallId String?   @map("preferred_mall_id")
  banned          Boolean?  @default(false)
  banReason       String?   @map("ban_reason")
  banExpires      DateTime? @map("ban_expires")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @default(now()) @updatedAt @map("updated_at")

  sessions                    Session[]
  accounts                    Account[]
  organizationMemberships     Member[]
  sentOrganizationInvitations Invitation[] @relation("OrganizationInvitationInviter")

  profile       UserProfile?
  preferredMall Mall?        @relation("PreferredMall", fields: [preferredMallId], references: [id], onDelete: SetNull)

  managedMalls          Mall[]                     @relation("MallAdmin")
  ownedStores           Store[]                    @relation("StoreOwner")
  reservations          Reservation[]              @relation("ReservationCustomer")
  appliedStoreRequests  StoreRegistrationRequest[] @relation("StoreApplicant")
  reviewedStoreRequests StoreRegistrationRequest[] @relation("StoreReviewer")
  createdPromotions     Promotion[]                @relation("PromotionCreator")
  updatedPromotions     Promotion[]                @relation("PromotionUpdater")
  aiRuns                AiRun[]                    @relation("AiRunRequester")

  favoriteStores     FavoriteStore[]
  favoriteProducts   FavoriteProduct[]
  favoritePromotions FavoritePromotion[]
  searchLogs         SearchLog[]

  createdAdminCcAssignments      AdminCcAssignment[]      @relation("AdminCcAssignmentCreator")
  adminCcAssignments             AdminCcAssignment[]      @relation("AdminCcAssignmentAssignee")
  auditEvents                    AuditEvent[]             @relation("AuditEventActor")
  createdModerationReports       ModerationReport[]       @relation("ModerationReportReporter")
  reviewedModerationReports      ModerationReport[]       @relation("ModerationReportReviewer")
  createdBillingSubscriptions    BillingSubscription[]    @relation("BillingSubscriptionCreator")
  updatedBillingSubscriptions    BillingSubscription[]    @relation("BillingSubscriptionUpdater")
  registeredBillingPayments      BillingPayment[]         @relation("BillingPaymentRegistrar")
  createdBillingCollectionAlerts BillingCollectionAlert[] @relation("BillingCollectionAlertCreator")
  createdCampaigns               Campaign[]               @relation("CampaignCreator")
  updatedCampaigns               Campaign[]               @relation("CampaignUpdater")

  @@index([preferredMallId], map: "users_preferredMallId_idx")
  @@index([role], map: "users_role_idx")
  @@map("users")
}

model Session {
  id                   String        @id
  expiresAt            DateTime      @map("expires_at")
  token                String        @unique
  createdAt            DateTime      @default(now()) @map("created_at")
  updatedAt            DateTime      @default(now()) @updatedAt @map("updated_at")
  ipAddress            String?       @map("ip_address")
  userAgent            String?       @map("user_agent")
  userId               String        @map("user_id")
  impersonatedBy       String?       @map("impersonated_by")
  activeOrganizationId String?       @map("active_organization_id")
  user                 User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  activeOrganization   Organization? @relation(fields: [activeOrganizationId], references: [id], onDelete: SetNull)

  @@index([userId], map: "sessions_userId_idx")
  @@index([activeOrganizationId], map: "sessions_activeOrganizationId_idx")
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")
  providerId            String    @map("provider_id")
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @default(now()) @updatedAt @map("updated_at")
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId], map: "accounts_userId_idx")
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at")

  @@index([identifier], map: "verifications_identifier_idx")
  @@map("verifications")
}

model Organization {
  id        String    @id
  name      String
  slug      String    @unique
  logo      String?
  metadata  Json?
  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime? @map("updated_at")

  activeSessions Session[]
  members        Member[]
  invitations    Invitation[]

  @@map("organizations")
}

model Member {
  id             String   @id
  organizationId String   @map("organization_id")
  userId         String   @map("user_id")
  role           String   @default("member")
  createdAt      DateTime @default(now()) @map("created_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId], map: "members_organization_user_key")
  @@index([organizationId], map: "members_organizationId_idx")
  @@index([userId], map: "members_userId_idx")
  @@map("organization_members")
}

model Invitation {
  id             String   @id
  organizationId String   @map("organization_id")
  email          String
  role           String
  status         String   @default("pending")
  expiresAt      DateTime @map("expires_at")
  createdAt      DateTime @default(now()) @map("created_at")
  inviterId      String   @map("inviter_id")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inviter      User         @relation("OrganizationInvitationInviter", fields: [inviterId], references: [id], onDelete: Cascade)

  @@index([organizationId, status], map: "invitations_organization_status_idx")
  @@index([organizationId, email, status], map: "invitations_org_email_status_idx")
  @@index([email], map: "invitations_email_idx")
  @@index([inviterId], map: "invitations_inviterId_idx")
  @@map("organization_invitations")
}

model UserProfile {
  userId                 String   @id @map("user_id")
  displayName            String?  @map("display_name")
  avatarUrl              String?  @map("avatar_url")
  highContrastEnabled    Boolean  @default(false) @map("high_contrast_enabled")
  fontScalePct           Int      @default(100) @map("font_scale_pct")
  favoriteFeatureEnabled Boolean  @default(true) @map("favorite_feature_enabled")
  updatedAt              DateTime @default(now()) @updatedAt @map("updated_at")
  user                   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_profiles")
}

enum EventStatus {
  DRAFT
  PUBLISHED
  CANCELLED
}

model Mall {
  id            String     @id @default(cuid())
  name          String
  city          String
  address       String
  description   String?
  heroImageUrl  String?    @map("hero_image_url")
  configMapSvg  String?    @map("config_map_svg") @db.Text
  status        MallStatus @default(INACTIVE)
  adminCcUserId String?    @map("admin_cc_user_id")
  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @default(now()) @updatedAt @map("updated_at")

  adminCcUser         User?                      @relation("MallAdmin", fields: [adminCcUserId], references: [id], onDelete: SetNull)
  preferredByUsers    User[]                     @relation("PreferredMall")
  stores              Store[]
  products            Product[]
  registrations       StoreRegistrationRequest[]
  promotions          Promotion[]
  reservations        Reservation[]
  searchLogs          SearchLog[]
  dailyMetrics        DailyMallMetric[]
  aiRuns              AiRun[]
  adminCcAssignments  AdminCcAssignment[]
  moderationReports   ModerationReport[]
  billingSubscription BillingSubscription?       @relation("MallBillingSubscription")
  campaignTargets     CampaignTargetMall[]
  events              MallEvent[]

  @@index([status], map: "malls_status_idx")
  @@index([adminCcUserId], map: "malls_adminCcUserId_idx")
  @@map("malls")
}

model MallEvent {
  id          String      @id @default(cuid())
  mallId      String      @map("mall_id")
  name        String
  description String?
  startDate   DateTime    @map("start_date")
  endDate     DateTime    @map("end_date")
  status      EventStatus @default(DRAFT)
  createdAt   DateTime    @default(now()) @map("created_at")
  updatedAt   DateTime    @default(now()) @updatedAt @map("updated_at")

  mall Mall @relation(fields: [mallId], references: [id], onDelete: Cascade)

  @@index([mallId, status], map: "mall_events_mall_status_idx")
  @@index([startDate, endDate], map: "mall_events_dates_idx")
  @@map("mall_events")
}

model Store {
  id           String      @id @default(cuid())
  mallId       String      @map("mall_id")
  ownerUserId  String?     @map("owner_user_id")
  name         String
  category     String?
  description  String?
  logoImageUrl String?     @map("logo_image_url")
  floor        String?
  openHours    String?     @map("open_hours")
  phone        String?
  contactEmail String?     @map("contact_email")
  status       StoreStatus @default(PENDING_APPROVAL)
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @default(now()) @updatedAt @map("updated_at")

  mall  Mall  @relation(fields: [mallId], references: [id], onDelete: Cascade)
  owner User? @relation("StoreOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  products            Product[]
  promotions          Promotion[]
  reservations        Reservation[]
  aiRuns              AiRun[]
  favoriteStores      FavoriteStore[]
  approvedFromRequest StoreRegistrationRequest? @relation("ApprovedStore")
  moderationReports   ModerationReport[]
  billingSubscription BillingSubscription?      @relation("StoreBillingSubscription")

  @@index([mallId], map: "stores_mallId_idx")
  @@index([ownerUserId], map: "stores_ownerUserId_idx")
  @@index([status], map: "stores_status_idx")
  @@map("stores")
}

model StoreRegistrationRequest {
  id               String                         @id @default(cuid())
  mallId           String                         @map("mall_id")
  applicantUserId  String                         @map("applicant_user_id")
  storeName        String                         @map("store_name")
  category         String?
  description      String?
  contactEmail     String?                        @map("contact_email")
  contactPhone     String?                        @map("contact_phone")
  status           StoreRegistrationRequestStatus @default(PENDING)
  reviewNotes      String?                        @map("review_notes")
  reviewedByUserId String?                        @map("reviewed_by_user_id")
  createdStoreId   String?                        @unique @map("created_store_id")
  createdAt        DateTime                       @default(now()) @map("created_at")
  updatedAt        DateTime                       @default(now()) @updatedAt @map("updated_at")
  reviewedAt       DateTime?                      @map("reviewed_at")

  mall         Mall   @relation(fields: [mallId], references: [id], onDelete: Cascade)
  applicant    User   @relation("StoreApplicant", fields: [applicantUserId], references: [id], onDelete: Cascade)
  reviewedBy   User?  @relation("StoreReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)
  createdStore Store? @relation("ApprovedStore", fields: [createdStoreId], references: [id], onDelete: SetNull)

  @@index([mallId, status], map: "store_registration_requests_mall_status_idx")
  @@index([applicantUserId], map: "store_registration_requests_applicant_idx")
  @@map("store_registration_requests")
}

model BillingSubscription {
  id                 String                    @id @default(cuid())
  targetType         BillingTargetType         @map("target_type")
  mallId             String?                   @unique(map: "billing_subscriptions_mall_id_key") @map("mall_id")
  storeId            String?                   @unique(map: "billing_subscriptions_store_id_key") @map("store_id")
  planCode           BillingPlanCode           @map("plan_code")
  status             BillingSubscriptionStatus @default(ACTIVE)
  recurringAmount    Decimal                   @default(0) @map("recurring_amount") @db.Decimal(12, 2)
  currentPeriodStart DateTime                  @map("current_period_start")
  currentPeriodEnd   DateTime?                 @map("current_period_end")
  nextPaymentDueAt   DateTime?                 @map("next_payment_due_at")
  lastPaymentAt      DateTime?                 @map("last_payment_at")
  createdByUserId    String?                   @map("created_by_user_id")
  updatedByUserId    String?                   @map("updated_by_user_id")
  createdAt          DateTime                  @default(now()) @map("created_at")
  updatedAt          DateTime                  @default(now()) @updatedAt @map("updated_at")

  mall          Mall?  @relation("MallBillingSubscription", fields: [mallId], references: [id], onDelete: Cascade)
  store         Store? @relation("StoreBillingSubscription", fields: [storeId], references: [id], onDelete: Cascade)
  createdByUser User?  @relation("BillingSubscriptionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User?  @relation("BillingSubscriptionUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  payments         BillingPayment[]
  collectionAlerts BillingCollectionAlert[]

  @@index([targetType, status, nextPaymentDueAt], map: "billing_subscriptions_target_status_due_idx")
  @@index([planCode], map: "billing_subscriptions_plan_code_idx")
  @@map("billing_subscriptions")
}

model BillingPayment {
  id                 String   @id @default(cuid())
  subscriptionId     String   @map("subscription_id")
  amount             Decimal  @db.Decimal(12, 2)
  currency           String   @default("USD")
  paidAt             DateTime @map("paid_at")
  paymentMethod      BillingPaymentMethod @default(BANK_TRANSFER) @map("payment_method")
  reference          String?  @map("reference")
  notes              String?
  registeredByUserId String   @map("registered_by_user_id")
  createdAt          DateTime @default(now()) @map("created_at")

  subscription     BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  registeredByUser User                @relation("BillingPaymentRegistrar", fields: [registeredByUserId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, paidAt], map: "billing_payments_subscription_paid_at_idx")
  @@index([registeredByUserId], map: "billing_payments_registered_by_user_id_idx")
  @@map("billing_payments")
}

model BillingCollectionAlert {
  id              String   @id @default(cuid())
  subscriptionId  String   @map("subscription_id")
  reason          String?
  sentAt          DateTime @default(now()) @map("sent_at")
  createdByUserId String   @map("created_by_user_id")
  createdAt       DateTime @default(now()) @map("created_at")

  subscription  BillingSubscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)
  createdByUser User                @relation("BillingCollectionAlertCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)

  @@index([subscriptionId, sentAt], map: "billing_collection_alerts_subscription_sent_at_idx")
  @@index([createdByUserId], map: "billing_collection_alerts_created_by_user_id_idx")
  @@map("billing_collection_alerts")
}

model Campaign {
  id              String             @id @default(cuid())
  name            String
  advertiserName  String             @map("advertiser_name")
  bannerType      CampaignBannerType @map("banner_type")
  imageUrl        String             @map("image_url")
  destinationUrl  String             @map("destination_url")
  status          CampaignStatus     @default(DRAFT)
  startsAt        DateTime           @map("starts_at")
  endsAt          DateTime           @map("ends_at")
  activatedAt     DateTime?          @map("activated_at")
  pausedAt        DateTime?          @map("paused_at")
  expiredAt       DateTime?          @map("expired_at")
  createdByUserId String?            @map("created_by_user_id")
  updatedByUserId String?            @map("updated_by_user_id")
  createdAt       DateTime           @default(now()) @map("created_at")
  updatedAt       DateTime           @default(now()) @updatedAt @map("updated_at")

  createdByUser User? @relation("CampaignCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("CampaignUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  targetMalls  CampaignTargetMall[]
  dailyMetrics CampaignDailyMetric[]

  @@index([status, startsAt, endsAt], map: "campaigns_status_schedule_idx")
  @@index([advertiserName], map: "campaigns_advertiser_name_idx")
  @@index([createdAt], map: "campaigns_created_at_idx")
  @@map("campaigns")
}

model CampaignTargetMall {
  campaignId String   @map("campaign_id")
  mallId     String   @map("mall_id")
  createdAt  DateTime @default(now()) @map("created_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  mall     Mall     @relation(fields: [mallId], references: [id], onDelete: Cascade)

  @@id([campaignId, mallId])
  @@index([mallId], map: "campaign_target_malls_mall_id_idx")
  @@map("campaign_target_malls")
}

model CampaignDailyMetric {
  id          String   @id @default(cuid())
  campaignId  String   @map("campaign_id")
  metricDate  DateTime @map("metric_date") @db.Date
  impressions Int      @default(0)
  clicks      Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at")

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@unique([campaignId, metricDate], map: "campaign_daily_metrics_campaign_date_key")
  @@index([metricDate], map: "campaign_daily_metrics_metric_date_idx")
  @@map("campaign_daily_metrics")
}

model Product {
  id            String        @id @default(cuid())
  mallId        String        @map("mall_id")
  storeId       String        @map("store_id")
  name          String
  category      String?
  description   String?
  status        ProductStatus @default(DRAFT)
  priceOriginal Decimal       @map("price_original") @db.Decimal(12, 2)
  priceDiscount Decimal?      @map("price_discount") @db.Decimal(12, 2)
  stock         Int           @default(0)
  isReservable  Boolean       @default(true) @map("is_reservable")
  variantsJson  String?       @map("variants_json") @db.Text
  aiAssisted    Boolean       @default(false) @map("ai_assisted")
  createdAt     DateTime      @default(now()) @map("created_at")
  updatedAt     DateTime      @default(now()) @updatedAt @map("updated_at")

  mall  Mall  @relation(fields: [mallId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  reservations      Reservation[]
  favoriteProducts  FavoriteProduct[]
  moderationReports ModerationReport[]

  @@index([mallId], map: "products_mallId_idx")
  @@index([storeId], map: "products_storeId_idx")
  @@index([status], map: "products_status_idx")
  @@map("products")
}

model Promotion {
  id              String          @id @default(cuid())
  mallId          String          @map("mall_id")
  storeId         String          @map("store_id")
  title           String
  description     String?
  status          PromotionStatus @default(DRAFT)
  startsAt        DateTime?       @map("starts_at")
  endsAt          DateTime?       @map("ends_at")
  createdByUserId String?         @map("created_by_user_id")
  updatedByUserId String?         @map("updated_by_user_id")
  createdAt       DateTime        @default(now()) @map("created_at")
  updatedAt       DateTime        @default(now()) @updatedAt @map("updated_at")

  mall  Mall  @relation(fields: [mallId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  createdByUser User? @relation("PromotionCreator", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("PromotionUpdater", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  favoritePromotions FavoritePromotion[]

  @@index([mallId, status], map: "promotions_mall_status_idx")
  @@index([storeId, status], map: "promotions_store_status_idx")
  @@map("promotions")
}

model Reservation {
  id             String            @id @default(cuid())
  mallId         String            @map("mall_id")
  storeId        String            @map("store_id")
  productId      String            @map("product_id")
  customerUserId String            @map("customer_user_id")
  status         ReservationStatus @default(PENDING)
  quantity       Int               @default(1)
  pickupFullName String            @map("pickup_full_name")
  pickupPhone    String            @map("pickup_phone")
  pickupNote     String?           @map("pickup_note")
  qrCodeValue    String            @unique @map("qr_code_value")
  requestedAt    DateTime          @default(now()) @map("requested_at")
  confirmedAt    DateTime?         @map("confirmed_at")
  completedAt    DateTime?         @map("completed_at")
  canceledAt     DateTime?         @map("canceled_at")
  statusReason   String?           @map("status_reason")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @default(now()) @updatedAt @map("updated_at")

  mall         Mall    @relation(fields: [mallId], references: [id], onDelete: Cascade)
  store        Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  product      Product @relation(fields: [productId], references: [id], onDelete: Cascade)
  customerUser User    @relation("ReservationCustomer", fields: [customerUserId], references: [id], onDelete: Cascade)

  @@index([customerUserId, status], map: "reservations_customer_status_idx")
  @@index([storeId, status], map: "reservations_store_status_idx")
  @@map("reservations")
}

model FavoriteStore {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  storeId   String   @map("store_id")
  createdAt DateTime @default(now()) @map("created_at")

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@unique([userId, storeId], map: "favorite_stores_user_store_key")
  @@map("favorite_stores")
}

model FavoriteProduct {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  productId String   @map("product_id")
  createdAt DateTime @default(now()) @map("created_at")

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@unique([userId, productId], map: "favorite_products_user_product_key")
  @@map("favorite_products")
}

model FavoritePromotion {
