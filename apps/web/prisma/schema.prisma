model ModerationReport {
  id               String                     @id @default(cuid())
  targetType       ModerationReportTargetType @map("target_type")
  reason           String
  detailsJson      Json?                      @map("details_json")
  status           ModerationReportStatus     @default(OPEN)
  resolutionAction ModerationDecisionAction?  @map("resolution_action")
  resolutionReason String?                    @map("resolution_reason")
  productId        String?                    @map("product_id")
  storeId          String?                    @map("store_id")
  mallId           String?                    @map("mall_id")
  reportedByUserId String?                    @map("reported_by_user_id")
  reviewedByUserId String?                    @map("reviewed_by_user_id")
  createdAt        DateTime                   @default(now()) @map("created_at")
  updatedAt        DateTime                   @default(now()) @updatedAt @map("updated_at")
  reviewedAt       DateTime?                  @map("reviewed_at")

  product        Product? @relation(fields: [productId], references: [id], onDelete: SetNull)
  store          Store?   @relation(fields: [storeId], references: [id], onDelete: SetNull)
  mall           Mall?    @relation(fields: [mallId], references: [id], onDelete: SetNull)
  reportedByUser User?    @relation("ModerationReportReporter", fields: [reportedByUserId], references: [id], onDelete: SetNull)
  reviewedByUser User?    @relation("ModerationReportReviewer", fields: [reviewedByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt], map: "moderation_reports_status_created_at_idx")
  @@index([targetType, status, createdAt], map: "moderation_reports_target_status_created_at_idx")
  @@index([productId], map: "moderation_reports_product_id_idx")
  @@index([storeId], map: "moderation_reports_store_id_idx")
  @@index([mallId], map: "moderation_reports_mall_id_idx")
  @@map("moderation_reports")
}

model AuditEvent {
  id           String            @id @default(cuid())
  actorUserId  String?           @map("actor_user_id")
  action       String
  targetType   String            @map("target_type")
  targetId     String?           @map("target_id")
  outcome      AuditEventOutcome @default(SUCCESS)
  metadataJson Json?             @map("metadata_json")
  createdAt    DateTime          @default(now()) @map("created_at")

  actorUser User? @relation("AuditEventActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([actorUserId, createdAt], map: "audit_events_actor_created_at_idx")
  @@index([action, createdAt], map: "audit_events_action_created_at_idx")
  @@index([targetType, targetId, createdAt], map: "audit_events_target_created_at_idx")
  @@map("audit_events")
}

