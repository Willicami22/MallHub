  queryText   String   @map("query_text")
  filtersJson Json?    @map("filters_json")
  createdAt   DateTime @default(now()) @map("created_at")

  mall Mall  @relation(fields: [mallId], references: [id], onDelete: Cascade)
  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([mallId, createdAt], map: "search_logs_mall_createdAt_idx")
  @@index([userId], map: "search_logs_userId_idx")
  @@map("search_logs")
}

