{
	"name": "@mallhub/web",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "pnpm run i18n:compile && prisma generate && react-router build",
		"dev": "pnpm run i18n:compile && prisma generate && react-router dev --host",
		"format": "biome check --write --unsafe .",
		"i18n:compile": "paraglide-js compile --project ../../project.inlang --outdir ./app/paraglide --strategy url,baseLocale",
		"lint": "biome check .",
		"prisma:generate": "prisma generate",
		"prisma:migrate": "prisma migrate dev",
		"prisma:studio": "prisma studio",
		"prisma:seed": "tsx prisma/seed.ts",
		"prisma:push": "prisma db push",
		"start": "react-router-serve ./build/server/index.js",
		"type-check": "pnpm run i18n:compile && prisma generate && react-router typegen && tsc"
	},
	"dependencies": {
		"@better-auth/prisma-adapter": "^1.5.6",
		"@casl/ability": "^6.8.0",
		"@casl/prisma": "^1.6.1",
		"@hugeicons/core-free-icons": "^4.1.1",
		"@hugeicons/react": "^1.1.6",
		"@mallhub/notifications": "workspace:*",
		"@mallhub/ui": "workspace:*",
		"@prisma/adapter-pg": "^7.0.0",
		"@prisma/client": "^7.0.0",
		"@react-router/node": "7.13.2",
		"@react-router/serve": "7.13.2",
		"@tanstack/react-form": "^1.28.6",
		"@tanstack/react-query": "^5.95.2",
		"@tanstack/react-table": "^8.21.3",
		"@trpc/client": "^11.16.0",
		"@trpc/server": "^11.16.0",
		"@trpc/tanstack-react-query": "^11.16.0",
		"better-auth": "^1.5.6",
		"dotenv": "^17.3.1",
		"isbot": "^5.1.36",
		"next-themes": "^0.4.6",
		"pg": "^8.16.3",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "7.13.2",
		"resend": "^6.12.2",
		"superjson": "^2.2.6",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@inlang/paraglide-js": "^2.15.1",
		"@react-router/dev": "7.13.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"prisma": "^7.0.0",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	}
}
