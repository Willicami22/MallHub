{
	"name": "@mallhub/web",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "react-router build",
		"dev": "react-router dev --host",
		"format": "biome check --write --unsafe .",
		"lint": "biome check .",
		"drizzle-kit": "drizzle-kit --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:generate": "drizzle-kit generate --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:migrate": "drizzle-kit migrate --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:push": "drizzle-kit push --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:studio": "drizzle-kit studio --config './app/features/.server/drizzle/drizzle.config.ts'",
		"drizzle-kit:seed": "tsx ./app/features/.server/drizzle/drizzle.seed.ts",
		"start": "react-router-serve ./build/server/index.js",
		"type-check": "react-router typegen && tsc"
	},
	"dependencies": {
		"@mallhub/ui": "workspace:*",
		"@react-router/node": "7.13.2",
		"@react-router/serve": "7.13.2",
		"@tanstack/react-query": "^5.95.2",
		"@trpc/client": "^11.16.0",
		"@trpc/server": "^11.16.0",
		"@trpc/tanstack-react-query": "^11.16.0",
		"better-auth": "^1.5.6",
		"dotenv": "^17.3.1",
		"drizzle-orm": "^0.45.2",
		"isbot": "^5.1.36",
		"next-themes": "^0.4.6",
		"react": "^19.2.4",
		"react-dom": "^19.2.4",
		"react-router": "7.13.2",
		"superjson": "^2.2.6",
		"zod": "^4.3.6"
	},
	"devDependencies": {
		"@react-router/dev": "7.13.2",
		"@tailwindcss/vite": "^4.2.2",
		"@types/node": "^25.5.0",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"drizzle-kit": "^0.31.10",
		"tailwindcss": "^4.2.2",
		"tsx": "^4.21.0",
		"typescript": "^6.0.2",
		"vite": "^8.0.3"
	}
}
