Project mallhub_mvp {
  database_type: 'PostgreSQL'
  Note: '''
  MVP v1.0 data schema aligned to docs/use-cases-by-role.md and SRS use cases.
  Scope is limited to MVP use cases only.
  Explicitly excluded from schema scope: US-CR-14, US-AP-20, US-AP-21 (deferred).
  Geolocation history is intentionally not persisted server-side.
  '''
}

Enum user_role {
  customer
  admin_local
  admin_cc
  admin_platform
}

Enum account_status {
  pending_verification
  active
  suspended
}

Enum notification_preference_type {
  offers_promotions
  reservations
  event_reminders
  price_changes
  stock_updates
  favorite_store_updates
  proximity
  system_alerts
}

Enum onboarding_request_status {
  pending
  approved
  rejected
}

Enum mall_status {
  inactive
  active
  suspended
}

Enum store_status {
  draft_onboarding
  pending_approval
  active
  suspended
  rejected
}

Enum media_kind {
  logo
  gallery
}

Enum product_status {
  draft
  active
  inactive
  archived
}

Enum stock_status {
  in_stock
  out_of_stock
}

Enum reservation_status {
  pending
  confirmed
  completed
  canceled
}

Enum promotion_type {
  standard
  flash
}

Enum promotion_status {
  scheduled
  active
  inactive
  expired
}

Enum event_status {
  draft
  published
  canceled
  completed
}

Enum event_audience {
  all_mall_users
  active_profile_only
}

Enum schedule_status {
  scheduled
  sent
  canceled
  failed
}

Enum notification_channel {
  push
  email
  in_app
}

Enum notification_type {
  reservation_created
  reservation_confirmed
  reservation_rejected
  reservation_canceled
  promotion_new
  price_drop
  stock_back
  event_reminder_24h
  event_reminder_1h
  event_push
  store_alert
  billing_alert
  ai_critical_alert
  system_incident
}

Enum delivery_status {
  queued
  sent
  failed
  read
}

Enum service_status {
  operational
  degraded
  incident
}

Enum incident_status {
  open
  resolved
}

Enum moderation_status {
  pending
  removed
  dismissed
}

Enum plan_scope {
  mall
  store
}

Enum subscription_status {
  trial
  active
  expired
  suspended
  canceled
}

Enum billing_status {
  up_to_date
  pending_payment
  overdue
}

Enum ai_job_type {
  catalog_assist
  executive_report
  alert_detection
  natural_query
}

Enum ai_job_status {
  success
  failed
}

Enum ai_alert_severity {
  critical
  warning
  info
}

Table users {
  id uuid [pk]
  email varchar(255) [not null, unique]
  password_hash varchar(255) [not null]
  role user_role [not null]
  status account_status [not null, default: 'pending_verification']
  full_name varchar(150)
  phone varchar(30)
  preferred_mall_id uuid [ref: > malls.id]
  is_profile_complete boolean [not null, default: false]
  high_contrast_enabled boolean [not null, default: false]
  font_scale_pct int [not null, default: 100]
  email_verified_at timestamptz
  last_login_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    role
    preferred_mall_id
  }
}

Table auth_sessions {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  refresh_token_hash varchar(255) [not null]
  issued_at timestamptz [not null, default: `now()`]
  expires_at timestamptz [not null]
  revoked_at timestamptz
  last_seen_at timestamptz
  user_agent varchar(255)
  ip_address varchar(64)
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
    refresh_token_hash [unique]
    (user_id, expires_at)
  }
}

Table email_verification_tokens {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  token_hash varchar(255) [not null, unique]
  expires_at timestamptz [not null]
  used_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
  }
}

Table password_reset_tokens {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  token_hash varchar(255) [not null, unique]
  expires_at timestamptz [not null]
  used_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
  }
}

Table user_2fa_methods {
  id uuid [pk]
  user_id uuid [not null, unique, ref: > users.id]
  secret_encrypted text [not null]
  is_enabled boolean [not null, default: false]
  enabled_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]
}

Table user_2fa_backup_codes {
  id uuid [pk]
  user_2fa_method_id uuid [not null, ref: > user_2fa_methods.id]
  code_hash varchar(255) [not null]
  used_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_2fa_method_id
    (user_2fa_method_id, code_hash) [unique]
  }
}

Table user_devices {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  platform varchar(32) [not null]
  push_token varchar(255) [unique]
  notifications_permission_granted boolean [not null, default: true]
  last_seen_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    user_id
  }
}

Table user_notification_preferences {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  preference_type notification_preference_type [not null]
  is_enabled boolean [not null, default: true]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, preference_type) [unique]
  }
}

Table malls {
  id uuid [pk]
  name varchar(150) [not null]
  city varchar(120) [not null]
  address varchar(255) [not null]
  phone varchar(30)
  contact_email varchar(255)
  description text
  status mall_status [not null, default: 'inactive']
  admin_cc_user_id uuid [ref: > users.id]
  status_reason text
  status_changed_by_user_id uuid [ref: > users.id]
  activated_at timestamptz
  created_by_user_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    status
    (city, name)
    admin_cc_user_id
  }
}

Table mall_business_hours {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  weekday smallint [not null]
  opens_at time
  closes_at time
  is_closed boolean [not null, default: false]

  indexes {
    (mall_id, weekday) [unique]
  }
}

Table mall_social_links {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  network varchar(50) [not null]
  url varchar(255) [not null]

  indexes {
    (mall_id, network) [unique]
  }
}

Table mall_media {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  media_kind media_kind [not null]
  file_url varchar(255) [not null]
  sort_order int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    mall_id
    (mall_id, media_kind)
  }
}

Table mall_floors {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  level_number int [not null]
  label varchar(80) [not null]
  map_svg_url varchar(255)
  map_version int [not null, default: 1]
  updated_by_user_id uuid [ref: > users.id]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (mall_id, level_number) [unique]
  }
}

Table mall_store_categories {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  name varchar(100) [not null]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (mall_id, name) [unique]
  }
}

Table mall_onboarding_requests {
  id uuid [pk]
  requested_by_user_id uuid [not null, ref: > users.id]
  requested_mall_name varchar(150) [not null]
  city varchar(120) [not null]
  address varchar(255)
  contact_name varchar(150)
  contact_email varchar(255)
  contact_phone varchar(30)
  status onboarding_request_status [not null, default: 'pending']
  reviewed_by_user_id uuid [ref: > users.id]
  review_notes text
  created_at timestamptz [not null, default: `now()`]
  reviewed_at timestamptz

  indexes {
    status
    created_at
  }
}

Table stores {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  owner_user_id uuid [ref: > users.id]
  name varchar(150) [not null]
  description text
  primary_category_id uuid [ref: > mall_store_categories.id]
  mall_floor_id uuid [ref: > mall_floors.id]
  unit_number varchar(30)
  phone varchar(30)
  contact_email varchar(255)
  map_node_id varchar(120)
  status store_status [not null, default: 'draft_onboarding']
  status_reason text
  approval_requested_at timestamptz
  approved_at timestamptz
  rejected_at timestamptz
  suspended_at timestamptz
  reactivated_at timestamptz
  status_changed_by_user_id uuid [ref: > users.id]
  is_claimed boolean [not null, default: false]
  catalog_last_updated_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    mall_id
    (mall_id, status)
    (mall_id, primary_category_id)
    owner_user_id
  }
}

Table store_category_links {
  id uuid [pk]
  store_id uuid [not null, ref: > stores.id]
  category_id uuid [not null, ref: > mall_store_categories.id]

  indexes {
    (store_id, category_id) [unique]
    category_id
  }
}

Table store_business_hours {
  id uuid [pk]
  store_id uuid [not null, ref: > stores.id]
  weekday smallint [not null]
  opens_at time
  closes_at time
  is_closed boolean [not null, default: false]

  indexes {
    (store_id, weekday) [unique]
  }
}

Table store_media {
  id uuid [pk]
  store_id uuid [not null, ref: > stores.id]
  media_kind media_kind [not null]
  file_url varchar(255) [not null]
  sort_order int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    store_id
    (store_id, media_kind)
  }
}

Table store_claim_invitations {
  id uuid [pk]
  store_id uuid [not null, ref: > stores.id]
  email varchar(255) [not null]
  invited_by_user_id uuid [not null, ref: > users.id]
  token_hash varchar(255) [not null, unique]
  expires_at timestamptz [not null]
  accepted_at timestamptz
  accepted_by_user_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    store_id
    email
  }
}

Table store_reviews {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  store_id uuid [not null, ref: > stores.id]
  author_user_id uuid [ref: > users.id]
  reviewer_name varchar(150)
  rating int [not null]
  comment text
  source varchar(50) [not null, default: 'imported']
  published_at timestamptz [not null, default: `now()`]
  is_visible boolean [not null, default: true]

  Note: 'Read-only for MVP; in-app review authoring remains out of scope (US-CR-14 deferred).'

  indexes {
    store_id
    mall_id
    published_at
  }
}

Table product_categories {
  id uuid [pk]
  name varchar(100) [not null, unique]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
}

Table products {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  store_id uuid [not null, ref: > stores.id]
  name varchar(150) [not null]
  description text
  category_id uuid [ref: > product_categories.id]
  status product_status [not null, default: 'draft']
  stock_status stock_status [not null, default: 'in_stock']
  price_original numeric(12,2) [not null]
  price_discount numeric(12,2)
  is_reservable boolean [not null, default: true]
  ai_assisted boolean [not null, default: false]
  created_from_product_id uuid [ref: > products.id]
  published_at timestamptz
  archived_at timestamptz
  created_by_user_id uuid [ref: > users.id]
  updated_by_user_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    store_id
    (store_id, status)
    (mall_id, status)
    category_id
  }
}

Table product_images {
  id uuid [pk]
  product_id uuid [not null, ref: > products.id]
  file_url varchar(255) [not null]
  sort_order int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    product_id
  }
}

Table product_skus {
  id uuid [pk]
  product_id uuid [not null, ref: > products.id]
  sku_code varchar(80)
  attributes_json jsonb [not null]
  stock_quantity int [not null, default: 0]
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    product_id
    (product_id, sku_code) [unique]
  }
}

Table promotions {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  store_id uuid [not null, ref: > stores.id]
  title varchar(150) [not null]
  description text
  promotion_type promotion_type [not null]
  status promotion_status [not null, default: 'scheduled']
  image_url varchar(255)
  starts_at timestamptz
  ends_at timestamptz [not null]
  created_by_user_id uuid [ref: > users.id]
  updated_by_user_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (mall_id, status)
    (store_id, status)
    ends_at
  }
}

Table events {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  title varchar(150) [not null]
  description text
  event_type varchar(80)
  status event_status [not null, default: 'draft']
  audience event_audience [not null, default: 'all_mall_users']
  mall_floor_id uuid [ref: > mall_floors.id]
  location_detail varchar(255)
  image_url varchar(255)
  starts_at timestamptz [not null]
  ends_at timestamptz
  created_by_user_id uuid [ref: > users.id]
  updated_by_user_id uuid [ref: > users.id]
  canceled_at timestamptz
  cancellation_reason text
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (mall_id, status)
    starts_at
  }
}

Table event_reminders {
  id uuid [pk]
  event_id uuid [not null, ref: > events.id]
  user_id uuid [not null, ref: > users.id]
  is_active boolean [not null, default: true]
  activated_at timestamptz [not null, default: `now()`]
  deactivated_at timestamptz
  sent_24h_at timestamptz
  sent_1h_at timestamptz

  indexes {
    (event_id, user_id) [unique]
    user_id
  }
}

Table event_push_schedules {
  id uuid [pk]
  event_id uuid [not null, ref: > events.id]
  scheduled_by_user_id uuid [not null, ref: > users.id]
  audience event_audience [not null]
  scheduled_for timestamptz [not null]
  status schedule_status [not null, default: 'scheduled']
  sent_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    event_id
    (event_id, status, scheduled_for)
  }
}

Table event_metrics {
  event_id uuid [pk, ref: > events.id]
  detail_views int [not null, default: 0]
  reminders_activated int [not null, default: 0]
  traffic_impact_score numeric(10,2)
  updated_at timestamptz [not null, default: `now()`]
}

Table reservations {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  store_id uuid [not null, ref: > stores.id]
  product_id uuid [not null, ref: > products.id]
  product_sku_id uuid [ref: > product_skus.id]
  customer_user_id uuid [not null, ref: > users.id]
  status reservation_status [not null, default: 'pending']
  quantity int [not null, default: 1]
  pickup_full_name varchar(150) [not null]
  pickup_phone varchar(30) [not null]
  pickup_note varchar(200)
  pickup_eta_at timestamptz
  qr_code_value varchar(255) [not null, unique]
  requested_at timestamptz [not null, default: `now()`]
  confirmed_at timestamptz
  completed_at timestamptz
  canceled_at timestamptz
  expires_at timestamptz
  cancel_reason text
  canceled_by_user_id uuid [ref: > users.id]
  store_viewed_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (customer_user_id, status, requested_at)
    (store_id, status, requested_at)
    (customer_user_id, product_id, status)
    mall_id
  }
}

Table favorite_stores {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  store_id uuid [not null, ref: > stores.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, store_id) [unique]
  }
}

Table favorite_products {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  product_id uuid [not null, ref: > products.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, product_id) [unique]
  }
}

Table favorite_promotions {
  id uuid [pk]
  user_id uuid [not null, ref: > users.id]
  promotion_id uuid [not null, ref: > promotions.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (user_id, promotion_id) [unique]
  }
}

Table notifications {
  id uuid [pk]
  mall_id uuid [ref: > malls.id]
  store_id uuid [ref: > stores.id]
  recipient_user_id uuid [not null, ref: > users.id]
  channel notification_channel [not null]
  notification_type notification_type [not null]
  title varchar(180) [not null]
  body text [not null]
  related_entity_type varchar(80)
  related_entity_id uuid
  delivery_status delivery_status [not null, default: 'queued']
  scheduled_for timestamptz
  sent_at timestamptz
  read_at timestamptz
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (recipient_user_id, delivery_status, created_at)
    (mall_id, notification_type, created_at)
    (store_id, notification_type, created_at)
  }
}

Table search_logs {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  user_id uuid [ref: > users.id]
  is_guest boolean [not null, default: false]
  query_text varchar(255) [not null]
  matched_category_id uuid [ref: > product_categories.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    mall_id
    created_at
    matched_category_id
  }
}

Table daily_mall_metrics {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  metric_date date [not null]
  digital_visits int [not null, default: 0]
  searches_count int [not null, default: 0]
  reservations_total int [not null, default: 0]
  reservations_completed int [not null, default: 0]
  conversion_rate numeric(8,5) [not null, default: 0]
  active_stores int [not null, default: 0]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (mall_id, metric_date) [unique]
    metric_date
  }
}

Table daily_store_metrics {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  store_id uuid [not null, ref: > stores.id]
  metric_date date [not null]
  profile_visits int [not null, default: 0]
  product_views int [not null, default: 0]
  reservations_received int [not null, default: 0]
  reservations_completed int [not null, default: 0]
  active_products int [not null, default: 0]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (store_id, metric_date) [unique]
    (mall_id, metric_date)
  }
}

Table daily_product_metrics {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  store_id uuid [not null, ref: > stores.id]
  product_id uuid [not null, ref: > products.id]
  metric_date date [not null]
  views int [not null, default: 0]
  reservations_count int [not null, default: 0]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (product_id, metric_date) [unique]
    (store_id, metric_date)
    (mall_id, metric_date)
  }
}

Table platform_services {
  id uuid [pk]
  service_key varchar(50) [not null, unique]
  display_name varchar(120) [not null]
  current_status service_status [not null, default: 'operational']
  last_checked_at timestamptz
  updated_at timestamptz [not null, default: `now()`]
}

Table service_incidents {
  id uuid [pk]
  service_id uuid [not null, ref: > platform_services.id]
  status incident_status [not null, default: 'open']
  started_at timestamptz [not null]
  ended_at timestamptz
  details text
  detected_by_user_id uuid [ref: > users.id]
  resolved_by_user_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (service_id, status, started_at)
  }
}

Table moderation_cases {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  store_id uuid [ref: > stores.id]
  product_id uuid [ref: > products.id]
  product_image_id uuid [ref: > product_images.id]
  store_media_id uuid [ref: > store_media.id]
  mall_media_id uuid [ref: > mall_media.id]
  content_kind varchar(50) [not null]
  report_reason text [not null]
  status moderation_status [not null, default: 'pending']
  reported_by_user_id uuid [ref: > users.id]
  reviewed_by_user_id uuid [ref: > users.id]
  review_notes text
  created_at timestamptz [not null, default: `now()`]
  reviewed_at timestamptz

  indexes {
    (mall_id, status, created_at)
    status
  }
}

Table subscription_plans {
  id uuid [pk]
  scope plan_scope [not null]
  code varchar(50) [not null, unique]
  name varchar(120) [not null]
  is_pro boolean [not null, default: false]
  billing_period_days int [not null]
  price_amount numeric(12,2) [not null]
  currency char(3) [not null, default: 'COP']
  is_active boolean [not null, default: true]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (scope, is_active)
  }
}

Table mall_subscriptions {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  plan_id uuid [not null, ref: > subscription_plans.id]
  status subscription_status [not null, default: 'active']
  starts_at timestamptz [not null]
  ends_at timestamptz
  trial_ends_at timestamptz
  is_current boolean [not null, default: true]
  changed_by_user_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (mall_id, status)
    (mall_id, is_current)
  }
}

Table store_subscriptions {
  id uuid [pk]
  store_id uuid [not null, ref: > stores.id]
  plan_id uuid [not null, ref: > subscription_plans.id]
  status subscription_status [not null, default: 'active']
  starts_at timestamptz [not null]
  ends_at timestamptz
  trial_ends_at timestamptz
  is_current boolean [not null, default: true]
  changed_by_user_id uuid [ref: > users.id]
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (store_id, status)
    (store_id, is_current)
  }
}

Table billing_records {
  id uuid [pk]
  scope plan_scope [not null]
  mall_id uuid [ref: > malls.id]
  store_id uuid [ref: > stores.id]
  plan_code_snapshot varchar(50) [not null]
  amount_due numeric(12,2) [not null]
  currency char(3) [not null, default: 'COP']
  due_at timestamptz [not null]
  status billing_status [not null, default: 'pending_payment']
  period_start date
  period_end date
  paid_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (scope, status, due_at)
    mall_id
    store_id
  }
}

Table billing_payments {
  id uuid [pk]
  billing_record_id uuid [not null, ref: > billing_records.id]
  amount_paid numeric(12,2) [not null]
  currency char(3) [not null, default: 'COP']
  payment_method varchar(50) [not null]
  paid_at timestamptz [not null]
  recorded_by_user_id uuid [not null, ref: > users.id]
  notes text
  created_at timestamptz [not null, default: `now()`]

  indexes {
    billing_record_id
  }
}

Table ai_runs {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  store_id uuid [ref: > stores.id]
  requested_by_user_id uuid [not null, ref: > users.id]
  job_type ai_job_type [not null]
  job_status ai_job_status [not null]
  model_id varchar(80) [not null]
  prompt_text text
  response_text text
  input_payload_json jsonb
  response_payload_json jsonb
  tokens_used int
  latency_ms int
  error_message text
  created_at timestamptz [not null, default: `now()`]
  expires_at timestamptz

  indexes {
    (mall_id, job_type, created_at)
    requested_by_user_id
    store_id
  }
}

Table ai_generated_alerts {
  id uuid [pk]
  ai_run_id uuid [not null, ref: > ai_runs.id]
  mall_id uuid [not null, ref: > malls.id]
  store_id uuid [ref: > stores.id]
  severity ai_alert_severity [not null]
  title varchar(180) [not null]
  description text [not null]
  metric_name varchar(80)
  impact_value numeric(12,2)
  recommended_action text
  created_at timestamptz [not null, default: `now()`]

  indexes {
    (mall_id, severity, created_at)
    ai_run_id
  }
}

Table ai_alert_schedules {
  id uuid [pk]
  mall_id uuid [not null, ref: > malls.id]
  user_id uuid [not null, ref: > users.id]
  is_enabled boolean [not null, default: true]
  weekday smallint [not null]
  send_time time [not null]
  timezone varchar(64) [not null]
  last_sent_at timestamptz
  created_at timestamptz [not null, default: `now()`]
  updated_at timestamptz [not null, default: `now()`]

  indexes {
    (mall_id, user_id) [unique]
  }
}

Table audit_log_entries {
  id uuid [pk]
  created_at timestamptz [not null, default: `now()`]
  actor_user_id uuid [ref: > users.id]
  actor_role user_role
  action_type varchar(120) [not null]
  entity_type varchar(80) [not null]
  entity_id uuid
  mall_id uuid [ref: > malls.id]
  store_id uuid [ref: > stores.id]
  before_json jsonb
  after_json jsonb
  metadata_json jsonb
  is_immutable boolean [not null, default: true]

  Note: 'Append-only audit trail for sensitive backoffice operations.'

  indexes {
    created_at
    actor_user_id
    action_type
    mall_id
    store_id
  }
}
