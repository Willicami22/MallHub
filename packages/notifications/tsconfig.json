{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"strict": true,
		"noEmit": true,
		"declaration": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"lib": ["ES2022"],
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "tsdown.config.ts"]
}
