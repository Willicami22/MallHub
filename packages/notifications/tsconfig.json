{
	"compilerOptions": {
		"target": "ES2022",
		"module": "ESNext",
		"moduleResolution": "Bundler",
		"baseUrl": ".",
		"ignoreDeprecations": "6.0",
		"paths": {
			"@/*": ["src/*"]
		},
		"strict": true,
		"noEmit": true,
		"declaration": true,
		"skipLibCheck": true,
		"verbatimModuleSyntax": true,
		"lib": ["ES2022"],
		"types": ["node"]
	},
	"include": ["src/**/*.ts", "tsdown.config.ts"]
}
