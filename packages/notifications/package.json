{
	"name": "@mallhub/notifications",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"sideEffects": false,
	"main": "./dist/index.cjs",
	"module": "./dist/index.mjs",
	"types": "./dist/index.d.mts",
	"exports": {
		".": {
			"types": "./dist/index.d.mts",
			"import": "./dist/index.mjs",
			"require": "./dist/index.cjs"
		}
	},
	"files": [
		"dist"
	],
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"format": "biome check --write --unsafe .",
		"lint": "biome check .",
		"type-check": "tsc --noEmit"
	},
	"devDependencies": {
		"@types/node": "^25.6.0",
		"tsdown": "^0.21.9",
		"typescript": "^6.0.2"
	}
}
